class AimCanvas(QWidget):
    """Smooth, canvas-based aim dot with phosphor trail effect."""

    def __init__(self, parent=None):
        super().__init__(parent)
        self.setMinimumSize(400, 400)
        self.points_x = []
        self.points_y = []
        self.max_points = 60
        self.center_x = 0.0
        self.center_y = 0.0
        self.is_calibrated = False
        self.plot_range = PLOT_RANGE
        self.ring_radii = RING_RADII
        self.trail_color = QColor(COLORS['accent_good'])

    def update_aim(self, trace_x, trace_y, curr_x, curr_y, calibrated):
        """Update aim data and trigger repaint."""
        self.points_x = list(trace_x)
        self.points_y = list(trace_y)
        self.center_x = curr_x
        self.center_y = curr_y
        self.is_calibrated = calibrated
        self.update()

    def set_range(self, r):
        self.plot_range = r
        self.update()

    def paintEvent(self, event):
        painter = QPainter(self)
        painter.setRenderHint(QPainter.Antialiasing)

        # Background
        painter.fillRect(self.rect(), QColor(COLORS['bg_secondary']))

        # Center on widget
        w, h = self.width(), self.height()
        cx, cy = w // 2, h // 2
        scale = min(w, h) / (2 * self.plot_range) * 0.9

        # Draw target rings
        for r in self.ring_radii:
            ring_rect = QRectF(
                cx - r * scale, cy - r * scale,
                r * 2 * scale, r * 2 * scale
            )
            painter.setPen(QPen(QColor('#2A2A2A'), 1))
            painter.drawEllipse(ring_rect)

        # Draw crosshair
        painter.setPen(QPen(QColor('#333333'), 1))
        painter.drawLine(cx - 20, cy, cx + 20, cy)
        painter.drawLine(cx, cy - 20, cx, cy + 20)

        if not self.is_calibrated:
            return

        # Draw trail with fade effect (phosphor display style)
        if len(self.points_x) > 1:
            trail_pen = QPen(QColor(COLORS['accent_good']), 2)
            path = QPainterPath()
            offset = len(self.points_x) - min(len(self.points_x), self.max_points)
            pts = self.points_x[offset:]
            pts_y = self.points_y[offset:]

            if len(pts) > 0:
                path.moveTo(cx + (pts[0] - self.center_x) * scale,
                           cy - (pts_y[0] - self.center_y) * scale)
                for i in range(1, len(pts)):
                    path.lineTo(cx + (pts[i] - self.center_x) * scale,
                              cy - (pts_y[i] - self.center_y) * scale)
                painter.setPen(trail_pen)
                painter.drawPath(path)

        # Draw current position dot
        dot_x = cx + (self.center_x - self.center_x) * scale
        dot_y = cy - (self.center_y - self.center_y) * scale

        # Glow effect
        glow = QRadialGradient(dot_x, dot_y, 15)
        glow.setColorAt(0, QColor(COLORS['accent_good']))
        glow.setColorAt(1, QColor(0, 210, 106, 0))
        painter.fillRect(self.rect(), QBrush(glow))

        # Main dot
        painter.setBrush(QBrush(QColor(COLORS['accent_good'])))
        painter.setPen(Qt.NoPen)
        painter.drawEllipse(int(dot_x) - 6, int(dot_y) - 6, 12, 12)


class ShotTraceCanvas(QWidget):
    """Shot trace replay with zoom/pan/playback."""

    def __init__(self, parent=None):
        super().__init__(parent)
        self.setMinimumSize(400, 400)
        self.hold_x = []
        self.hold_y = []
        self.press_x = []
        self.press_y = []
        self.recoil_x = []
        self.recoil_y = []
        self.break_idx = 0
        self.playback_pos = 0
        self.is_playing = False
        self.scale = 1.0
        self.offset_x = 0.0
        self.offset_y = 0.0
        self.plot_range = PLOT_RANGE

    def set_trace(self, hold, press, recoil):
        self.hold_x, self.hold_y = hold
        self.press_x, self.press_y = press
        self.recoil_x, self.recoil_y = recoil
        self.playback_pos = len(self.press_x)
        self.update()

    def clear_trace(self):
        self.hold_x = self.hold_y = []
        self.press_x = self.press_y = []
        self.recoil_x = self.recoil_y = []
        self.playback_pos = 0
        self.update()

    def set_scale(self, s):
        self.scale = max(0.5, min(5.0, s))

    def paintEvent(self, event):
        painter = QPainter(self)
        painter.setRenderHint(QPainter.Antialiasing)
        painter.fillRect(self.rect(), QColor(COLORS['bg_secondary']))

        w, h = self.width(), self.height()
        cx, cy = w // 2, h // 2
        base_scale = min(w, h) / (2 * self.plot_range) * 0.9 * self.scale

        # Draw rings
        for r in self.ring_radii:
            ring_rect = QRectF(
                cx - r * base_scale, cy - r * base_scale,
                r * 2 * base_scale, r * 2 * base_scale
            )
            painter.setPen(QPen(QColor('#2A2A2A'), 1))
            painter.drawEllipse(ring_rect)

        # Draw crosshair
        painter.setPen(QPen(QColor('#333333'), 1))
        painter.drawLine(cx - 30, cy, cx + 30, cy)
        painter.drawLine(cx, cy - 30, cx, cy + 30)

        # Draw hold phase (red, subtle)
        if self.hold_x:
            painter.setPen(QPen(QColor('#FF5252', 150), 2))
            path = QPainterPath()
            path.moveTo(cx + self.hold_x[0] * base_scale, cy - self.hold_y[0] * base_scale)
            for i in range(1, len(self.hold_x)):
                path.lineTo(cx + self.hold_x[i] * base_scale, cy - self.hold_y[i] * base_scale)
            painter.drawPath(path)

        # Draw press phase (amber, prominent)
        if self.press_x:
            press_draw = min(self.playback_pos, len(self.press_x))
            if press_draw > 0:
                painter.setPen(QPen(QColor(COLORS['accent_ok']), 3))
                path = QPainterPath()
                path.moveTo(cx + self.press_x[0] * base_scale, cy - self.press_y[0] * base_scale)
                for i in range(1, press_draw):
                    path.lineTo(cx + self.press_x[i] * base_scale, cy - self.press_y[i] * base_scale)
                painter.drawPath(path)

                # Draw current position marker
                painter.setBrush(QBrush(QColor(COLORS['accent_ok'])))
                painter.drawEllipse(
                    int(cx + self.press_x[press_draw - 1] * base_scale) - 5,
                    int(cy - self.press_y[press_draw - 1] * base_scale) - 5, 10, 10)

        # Draw recoil phase (cyan)
        if self.recoil_x:
            painter.setPen(QPen(QColor('#00BCD4'), 2))
            path = QPainterPath()
            path.moveTo(cx + self.recoil_x[0] * base_scale, cy - self.recoil_y[0] * base_scale)
            for i in range(1, len(self.recoil_x)):
                path.lineTo(cx + self.recoil_x[i] * base_scale, cy - self.recoil_y[i] * base_scale)
            painter.drawPath(path)


