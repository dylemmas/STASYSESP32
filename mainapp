    def _update_stats(self):
        """Update session summary statistics."""
        if not self.shot_history:
            self.stat_avg.layout().itemAt(1).widget().setText("--")
            self.stat_best.layout().itemAt(1).widget().setText("--")
            self.stat_worst.layout().itemAt(1).widget().setText("--")
            self.stat_piezo.layout().itemAt(1).widget().setText("--")
            return

        scores = [s['score'] for s in self.shot_history]
        piezo_vals = [s['piezo'] for s in self.shot_history]

        avg_score = sum(scores) / len(scores)
        best_score = max(scores)
        worst_score = min(scores)
        avg_piezo = sum(piezo_vals) / len(piezo_vals)

        self.stat_avg.layout().itemAt(1).widget().setText(f"{avg_score:.1f}")
        self.stat_best.layout().itemAt(1).widget().setText(f"{best_score:.1f}")
        self.stat_worst.layout().itemAt(1).widget().setText(f"{worst_score:.1f}")
        self.stat_piezo.layout().itemAt(1).widget().setText(f"{avg_piezo:.0f}")

        # Color code avg score
        avg_color = COLORS['accent_good'] if avg_score > 90 else COLORS['accent_ok'] if avg_score > 70 else COLORS['accent_bad']
        self.stat_avg.layout().itemAt(1).widget().setStyleSheet(
            f"color: {avg_color}; font-size: 24px; font-weight: 600;")

    def _on_shot_selected(self, item):
        """Handle shot selection from history list."""
        idx = self.list_history.row(item)
        if 0 <= idx < len(self.shot_history):
            shot = self.shot_history[idx]
            self.trace_canvas.set_trace(shot['hold'], shot['press'], shot['recoil'])

    def _step_trace(self, delta):
        """Step forward/backward in trace playback."""
        if hasattr(self, 'trace_canvas'):
            self.trace_canvas.playback_pos = max(0, min(
                len(self.trace_canvas.press_x),
                self.trace_canvas.playback_pos + delta))
            self.trace_canvas.update()

    def _toggle_playback(self):
        """Toggle trace playback animation."""
        if hasattr(self, 'trace_canvas'):
            self.trace_canvas.playback_pos = 0
            self.trace_canvas.update()

    def _load_sessions(self):
        """Load all past sessions into history list."""
        self.list_sessions.clear()
        sessions = get_all_sessions()
        for row in sessions:
            item_text = f"{row['session_id']} | {row['mode']} | {row['shot_count']} shots"
            self.list_sessions.addItem(item_text)

    def _on_session_selected(self, item):
        """Handle session selection from history."""
        idx = self.list_sessions.row(item)
        sessions = get_all_sessions()
        if 0 <= idx < len(sessions):
            session = sessions[idx]
            shots = get_session_shots(session['session_id'])
            if shots:
                first_shot = shots[0]
                if first_shot['aim_trace']:
                    hold = (first_shot['aim_trace'].get('hold', {}).get('x', []),
                            first_shot['aim_trace'].get('hold', {}).get('y', []))
                    press = (first_shot['aim_trace'].get('press', {}).get('x', []),
                             first_shot['aim_trace'].get('press', {}).get('y', []))
                    recoil = (first_shot['aim_trace'].get('recoil', {}).get('x', []),
                               first_shot['aim_trace'].get('recoil', {}).get('y', []))
                    self.trace_canvas.set_trace(hold, press, recoil)

